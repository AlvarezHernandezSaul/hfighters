{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "productName": "HouseFighters",
  "version": "1.1.2",
  "identifier": "com.housefighters.app",  
  "app": {
    "windows": [
      {
        "title": "HouseFighters",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "withGlobalTauri": true
  },
